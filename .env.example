# OpenTag example environment
#
# Copy this file to .env for local experiments and replace placeholder values.
# Keep real tokens and private keys out of git.

# Shared dispatcher auth
# If set on the dispatcher, use the same value as OPENTAG_DISPATCHER_TOKEN in
# ingress apps and as OPENTAG_PAIRING_TOKEN for daemon/client pairing.
OPENTAG_PAIRING_TOKEN=dev_pairing_token
OPENTAG_DISPATCHER_TOKEN=dev_pairing_token

# Dispatcher app
# apps/dispatcher defaults to PORT=3030 and OPENTAG_DATABASE_PATH=opentag.db.
OPENTAG_DATABASE_PATH=opentag.db
OPENTAG_GITHUB_TOKEN=ghp_replace_me
OPENTAG_SLACK_BOT_TOKEN=xoxb-replace-me
OPENTAG_TELEGRAM_MODE=polling
OPENTAG_TELEGRAM_BOT_TOKEN=0000000000:replace-me
# OPENTAG_SLACK_BOT_TOKENS_JSON='{"opentag":"xoxb-replace-me"}'
# OPENTAG_TELEGRAM_BOT_TOKENS_JSON='{"opentag":"0000000000:replace-me"}'
# Discord Gateway is the local-first default. Webhook mode is advanced and
# requires OPENTAG_DISCORD_MODE=webhook plus OPENTAG_DISCORD_PUBLIC_KEY.
OPENTAG_DISCORD_MODE=gateway
OPENTAG_DISCORD_BOT_TOKEN=replace_me
# OPENTAG_DISCORD_PUBLIC_KEY=replace_me
# OPENTAG_DISCORD_WEBHOOK_PATH=/discord/interactions

# Linear workspace webhook and GraphQL callbacks.
# Local opentag start defaults to a separate Linear webhook listener on port 3070.
# Hosted/self-hosted dispatcher relay mode mounts /linear/webhooks in-process when
# OPENTAG_LINEAR_WEBHOOK_SECRET is set. The repo env binds Linear runs to a
# Project Target that the local runner has already paired/allowlisted.
OPENTAG_LINEAR_API_KEY=lin_api_replace_me
# OPENTAG_LINEAR_WEBHOOK_SECRET=replace_me
# OPENTAG_LINEAR_WEBHOOK_PATH=/linear/webhooks
# OPENTAG_LINEAR_GRAPHQL_URL=https://api.linear.app/graphql
# Hosted relay OAuth install API. Client id + redirect URI expose
# POST /v1/linear-oauth-installations plus /linear/oauth/callback. Add the
# OAuth App webhook secret to expose the fixed /linear/oauth/webhooks ingress
# that Linear should call after install.
# OPENTAG_LINEAR_OAUTH_CLIENT_ID=replace_me
# OPENTAG_LINEAR_OAUTH_CLIENT_SECRET=replace_me
# OPENTAG_LINEAR_OAUTH_REDIRECT_URI=https://relay.example.com/linear/oauth/callback
# OPENTAG_LINEAR_OAUTH_WEBHOOK_SECRET=replace_me
# OPENTAG_LINEAR_OAUTH_WEBHOOK_PATH=/linear/oauth/webhooks
# OPENTAG_LINEAR_OAUTH_SCOPES=read,write,comments:create,app:assignable,app:mentionable
# OPENTAG_LINEAR_REPO_PROVIDER=github
# OPENTAG_LINEAR_REPO_OWNER=amplifthq
# OPENTAG_LINEAR_REPO_NAME=opentag

# Live Linear workspace smoke test. These are only needed when running:
# corepack pnpm smoke:live -- --case linear-workspace-live
# OPENTAG_LINEAR_SMOKE_TOKEN='Bearer <linear-oauth-app-actor-access-token>'
# OPENTAG_LINEAR_SMOKE_ISSUE=ENG-123
# OPENTAG_LINEAR_SMOKE_ALLOW_NON_APP_TOKEN=false
# OPENTAG_LINEAR_SMOKE_AGENT_SESSION_ID=replace_me
# OPENTAG_LINEAR_SMOKE_DISCOVERY_LIMIT=100
# OPENTAG_LINEAR_SMOKE_GRAPHQL_URL=https://api.linear.app/graphql

# Daemon / local runner
# Prefer OPENTAG_CONFIG_PATH for repeatable setups. The repo variables below are
# useful for quick local env-derived binding tests.
# OPENTAG_CONFIG_PATH=opentag.local.json
OPENTAG_RUNNER_ID=runner_local
OPENTAG_DISPATCHER_URL=http://localhost:3030
OPENTAG_REPO_PROVIDER=github
OPENTAG_REPO_OWNER=amplifthq
OPENTAG_REPO_NAME=opentag
OPENTAG_WORKSPACE_PATH=/absolute/path/to/opentag
OPENTAG_DEFAULT_EXECUTOR=echo
OPENTAG_BASE_BRANCH=main
OPENTAG_PUSH_REMOTE=origin
# OPENTAG_WORKTREE_ROOT=/absolute/path/to/opentag-worktrees
# OPENTAG_KEEP_WORKTREE=on_failure
# Push executor run branches so a later source-thread `apply 1` can create the PR.
# OPENTAG_PREPARE_PR_BRANCH=false
# Legacy mode: create the PR immediately from the daemon after a successful run.
# OPENTAG_ALLOW_AUTO_CREATE_PR=false
# OPENTAG_POLL_INTERVAL_MS=5000
# OPENTAG_HEARTBEAT_INTERVAL_MS=15000

# Optional daemon security controls
# OPENTAG_SECURITY_MODE=enforce
# OPENTAG_ALLOWED_WORKSPACE_ROOT=/absolute/path/to
# OPENTAG_ALLOW_UNSAFE_PROMPTS=false
# OPENTAG_EXTRA_SAFE_ENV=OPENTAG_DEBUG

# Optional Claude Code executor controls
# OPENTAG_CLAUDE_COMMAND=claude
# OPENTAG_CLAUDE_MODEL=sonnet
# OPENTAG_CLAUDE_PERMISSION_MODE=acceptEdits
# OPENTAG_CLAUDE_DANGEROUSLY_SKIP_PERMISSIONS=false

# GitHub ingress app
# apps/github-probot uses Probot. Set PORT and WEBHOOK_PATH per process when needed.
# APP_ID=123456
# WEBHOOK_SECRET=replace_me
# PRIVATE_KEY_PATH=/absolute/path/to/github-app.private-key.pem
# WEBHOOK_PATH=/github/webhooks
# OPENTAG_DISPATCHER_OWNS_CALLBACKS=true

# Slack ingress app
# apps/slack-events defaults to PORT=3040.
SLACK_SIGNING_SECRET=replace_me
OPENTAG_SLACK_AGENT_ID=opentag
# OPENTAG_SLACK_APP_ID=A0123456789
# OPENTAG_SLACK_POST_MESSAGE_URL=https://slack.com/api/chat.postMessage
# OPENTAG_SLACK_APPS_JSON='[{"agentId":"opentag","signingSecret":"replace_me","appId":"A0123456789"}]'

# Optional env-derived Slack channel binding for opentagd.
OPENTAG_SLACK_TEAM_ID=T0123456789
OPENTAG_SLACK_CHANNEL_ID=C0123456789
OPENTAG_SLACK_REPO_PROVIDER=github

# Telegram webhook ingress app (advanced mode)
# apps/telegram-events defaults to PORT=3050. Local opentag start defaults to
# OPENTAG_TELEGRAM_MODE=polling and does not need a public webhook.
OPENTAG_TELEGRAM_BOT_ID=0000000000
OPENTAG_TELEGRAM_AGENT_ID=opentag
# OPENTAG_TELEGRAM_MODE=webhook
# OPENTAG_TELEGRAM_BOT_USERNAME=opentag_bot
# OPENTAG_TELEGRAM_SECRET_TOKEN=replace_me
# OPENTAG_TELEGRAM_CALLBACK_URI=https://api.telegram.org/sendMessage
# OPENTAG_TELEGRAM_BOTS_JSON='[{"mode":"webhook","botId":"0000000000","agentId":"opentag","botUsername":"opentag_bot","secretToken":"replace_me"}]'
